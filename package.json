{
  "name": "public-vault",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run generate:tasks && vp run typecheck && vp run build:site",
    "build:site": "vp build",
    "dev": "vp run generate:tasks && vp run dev:site",
    "dev:site": "vp dev",
    "format": "vp run format:write",
    "format:write": "prettier --write \"vault/**/*.md\" \"site/**/*.{ts,vue,css,html}\" \"scripts/**/*.ts\"",
    "generate:tasks": "vp run generate:tasks:raw",
    "generate:tasks:raw": "node scripts/generate-task-data.ts",
    "preview": "vp run preview:site",
    "preview:site": "vp preview",
    "test": "vp run generate:tasks && vp run test:site",
    "test:site": "vp test run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^6.0.5",
    "gray-matter": "^4.0.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vite-plus": "^0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.32.1"
}
